# ── Apify / Immobiliare.it listings sync ────────────────────────────────────
# Get your token at https://console.apify.com/account/integrations
APIFY_TOKEN=

# Demo tenant only: the original agency search page on Immobiliare.it.
# New tenants use the immobiliare_url they submit at signup.
IMMOBILIARE_SEARCH_URL=

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
# Signing secret (whsec_…) of the OpenAI project webhook. In the OpenAI
# dashboard (Settings → Webhooks) add an endpoint at {PUBLIC_BASE_URL}/call/incoming
# subscribed to the `realtime.call.incoming` event, then paste its secret here.
OPENAI_WEBHOOK_SECRET=

# ── Telephony (Twilio numbers → OpenAI SIP) ──────────────────────────────────
# Inbound calls arrive over SIP: in Twilio, create an Elastic SIP Trunk with an
# Origination URI of  sip:<OPENAI_PROJECT_ID>@sip.api.openai.com;transport=tls
# and attach each Apollonia number to that trunk. Calls then route to OpenAI,
# which fires the webhook above. Numbers are assigned manually per tenant — the
# app no longer sets a Twilio voice webhook.
# OPENAI_PROJECT_ID is only needed to build that SIP URI in the Twilio console;
# it's not read by the app. Find it in the OpenAI dashboard (Settings → General).
# TWILIO_ACCOUNT_SID / AUTH_TOKEN are used only by the dormant auto-provisioner.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Demo tenant's number (migrated into the tenants DB on first startup).
TWILIO_PHONE_NUMBER=
# Optional: second number for the Slovak-language demo tenant (locale='sk').
# When set, a "Štúdio Demo" tenant with Slovak seed listings + Slovak agent is
# created/bound to it at startup. Attach this number to the same SIP trunk.
TWILIO_PHONE_NUMBER_SK=

# ── Deployment ───────────────────────────────────────────────────────────────
PUBLIC_BASE_URL=http://localhost:8000

# ── Multi-tenant ─────────────────────────────────────────────────────────────
# Bearer token protecting GET /admin/tenants
ADMIN_TOKEN=
# Where the SQLite tenants DB lives (Render persistent disk in production).
# For local dev on Windows, point this somewhere writable, e.g. ./data
DATA_DIR=/data

# ── Email (Resend HTTP API — Render blocks outbound SMTP) ────────────────────
# LEAD_EMAIL is the platform owner's address: it receives signup notifications
# and is the fallback recipient for demo-tenant lead summaries.
LEAD_EMAIL=
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev
# Signing secret of the Resend "email.received" webhook (Webhooks → your endpoint
# → Signing Secret, starts with whsec_). When set, POST /leads/inbound-email
# verifies the signature. Leave blank to accept unverified while testing.
RESEND_WEBHOOK_SECRET=
# For the reply test to work on the free Resend domain, send outreach FROM your
# <id>.resend.app address so replies route back into Resend, e.g.:
# OUTREACH_FROM_EMAIL=adam@xxxxxx.resend.app  (set in the lead-gen section above)

# ── Stripe billing (Checkout) ────────────────────────────────────────────────
# Test keys for now (sk_test_… / whsec_…); swap to live keys before launch.
# STRIPE_SECRET_KEY: Developers → API keys (use a restricted key if possible).
# STRIPE_WEBHOOK_SECRET: signing secret of the POST /webhook endpoint you
# register in the Stripe Dashboard (Developers → Webhooks).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Demo tenant listings cache (GitHub CSV) ──────────────────────────────────
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_CSV_PATH=backend/data/listings.csv
GITHUB_BRANCH=main

# ── Lead generation / cold outreach (ApollonIA agency prospecting) ───────────
# Google Places API key (Places API + Place Details enabled).
# https://console.cloud.google.com/google/maps-apis/credentials
GOOGLE_PLACES_API_KEY=
# Sender address for outreach emails (must be a verified Resend domain).
# Falls back to RESEND_FROM when unset, e.g. adam@apollon-ia.com
OUTREACH_FROM_EMAIL=
# Reply-To for outreach: lead replies land here. Set to your real inbox so you
# can answer prospects directly (no DNS changes needed), e.g. info@apollon-ia.com
OUTREACH_REPLY_TO=
# Booking link surfaced in the dashboard / future templates.
CALENDLY_LINK=https://calendly.com/adam/demo
