# ── Apify / Immobiliare.it listings sync ────────────────────────────────────
# Get your token at https://console.apify.com/account/integrations
APIFY_TOKEN=

# The client's agency search page on Immobiliare.it (see instructions below)
IMMOBILIARE_SEARCH_URL=

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Twilio ───────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Deployment ───────────────────────────────────────────────────────────────
PUBLIC_BASE_URL=http://localhost:8000

# ── Lead capture (email) ─────────────────────────────────────────────────────
LEAD_EMAIL=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# ── Legacy — no longer used ──────────────────────────────────────────────────
# GITHUB_TOKEN=
# GITHUB_REPO=
# GITHUB_CSV_PATH=listings.csv
# GITHUB_BRANCH=main
# LISTINGS_SYNC_INTERVAL_SECONDS=900
