# ── Listings / GitHub ────────────────────────────────────────────────────────
# GitHub Personal Access Token with repo read scope (classic or fine-grained).
# If not set, the app loads seed data (8 fictional listings) instead.
GITHUB_TOKEN=

# Repository in "owner/repo-name" format
GITHUB_REPO=adambionexislab/listings-data

# Path to the CSV file inside the repository
GITHUB_CSV_PATH=listings.csv

# Branch to read from
GITHUB_BRANCH=main

# How often to re-fetch the CSV from GitHub, in seconds (default: 900 = 15 min)
LISTINGS_SYNC_INTERVAL_SECONDS=900


# ── OpenAI ────────────────────────────────────────────────────────────────────
# API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Twilio ────────────────────────────────────────────────────────────────────
# Account SID — starts with AC, found at https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Auth Token — found on the same page as the Account SID
TWILIO_AUTH_TOKEN=your_auth_token_here

# Your Twilio phone number in E.164 format (e.g. +39021234567)
TWILIO_PHONE_NUMBER=+14632326753

# ── Deployment ────────────────────────────────────────────────────────────────
# Full public HTTPS URL of this app, no trailing slash.
# The app uses this to build the Twilio webhook URL and the WebSocket wss:// URL.
# Example: https://ai-receptionist.onrender.com
PUBLIC_BASE_URL=https://your-app.onrender.com


# ── Lead capture email ────────────────────────────────────────────────────────
# Address that receives the post-call lead summary
LEAD_EMAIL=gombalaadam650@gmail.com

# SMTP credentials for sending lead emails.
# For Gmail: create an App Password at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be enabled on the Google account).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=gombalaadam650@gmail.com
SMTP_PASSWORD=dypm zkqa uwgw faup
